{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://singularity-flow.dev/schemas/portfolio.schema.json",
  "title": "Singularity Flow portfolio configuration",
  "type": "object",
  "required": ["version", "repositories", "approvalAuthorities", "initiativeProfiles", "initiativePhases"],
  "properties": {
    "version": { "const": 1 },
    "initiativeRoot": { "type": "string" },
    "templatesRoot": { "type": "string" },
    "jira": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "connection": { "type": "string", "minLength": 1 },
        "deployment": { "enum": ["cloud", "data-center"] },
        "allowedHosts": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "allowedProjects": { "type": "array", "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]{0,31}$" }, "uniqueItems": true },
        "authentication": {
          "type": "object",
          "properties": {
            "permitted": { "type": "array", "items": { "enum": ["user-token", "service-account", "pat"] }, "uniqueItems": true },
            "tokenExpiryWarningDays": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "read": {
          "type": "object",
          "properties": {
            "epics": { "type": "boolean" },
            "stories": { "type": "boolean" },
            "attachmentPolicy": { "enum": ["none", "metadata-only"] },
            "cacheMinutes": { "type": "integer", "minimum": 0, "maximum": 1440 }
          },
          "additionalProperties": false
        },
        "write": { "type": ["boolean", "object"] },
        "writeMode": { "enum": ["off", "preview", "approved"] },
        "writeOperations": { "type": "array", "items": { "enum": ["create-epic", "create-story", "update-owned-fields", "add-comment"] }, "uniqueItems": true },
        "allowedFields": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "projectKey": { "type": "string" },
        "epicIssueType": { "type": "string" },
        "storyIssueType": { "type": "string" }
      },
      "additionalProperties": true
    },
    "repositories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "minLength": 1 },
          "defaultBranch": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "metadata": {
            "type": "object",
            "propertyNames": { "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$" },
            "additionalProperties": { "type": ["string", "number", "boolean"] }
          }
        },
        "additionalProperties": true
      }
    },
    "approvalAuthorities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["email"],
              "properties": {
                "name": { "type": "string" },
                "email": { "type": "string", "format": "email" }
              }
            }
          }
        }
      }
    },
    "initiativeProfiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["phases"],
        "properties": {
          "label": { "type": "string" },
          "description": { "type": "string" },
          "phases": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true }
        }
      }
    },
    "initiativePhases": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "lanes": { "type": "array", "items": { "type": "string" } },
          "worldModelViews": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array" },
          "checklist": { "type": "array" },
          "bundleApproval": { "type": "object" }
        }
      }
    }
  },
  "additionalProperties": true
}
