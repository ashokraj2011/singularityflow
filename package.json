{
  "name": "singularity-flow",
  "version": "0.9.0",
  "description": "Singularity Flow: collision-safe sflow-* Copilot skills with YAML-configured work profiles, personas, templates, Git state transfer, and deterministic governance.",
  "type": "module",
  "bin": {
    "singularity-flow": "bin/singularity-flow.mjs",
    "sflow": "bin/singularity-flow.mjs",
    "sflow-about": "bin/sflow-about.mjs",
    "sflow-inbox": "bin/sflow-inbox.mjs",
    "sflow-next": "bin/sflow-next.mjs",
    "sflow-persona": "bin/sflow-persona.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "plugin/",
    "templates/",
    "schemas/",
    "examples/",
    "README.md",
    "HELP.md",
    "HOW-TO.md",
    "ARCHITECTURE.md",
    "VERIFICATION.md",
    "MIGRATION.md",
    "RELEASE-PHASE-INPUTS.md",
    "RELEASE-EPIC-STORY-LINEAGE.md",
    "DISTRIBUTION.md",
    "INITIATIVE-ORCHESTRATION.md",
    "PLANNING-STUDIO.md",
    "WORKSPACES.md",
    "RELEASE-INITIATIVE-ORCHESTRATION.md",
    "LICENSE"
  ],
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.mjs",
    "gate": "node scripts/gate.mjs",
    "pack:dry": "npm pack --dry-run",
    "install:local": "bash ./install.sh",
    "desktop:dev": "npm run dev --workspace singularity-flow-desktop",
    "desktop:build": "npm run build --workspace singularity-flow-desktop",
    "desktop:icons": "node scripts/create-windows-icon.mjs",
    "desktop:dist": "npm run desktop:package:current",
    "desktop:package:current": "node scripts/desktop-release.mjs package --platform current",
    "desktop:package:mac": "node scripts/desktop-release.mjs package --platform mac",
    "desktop:package:win": "node scripts/desktop-release.mjs package --platform win",
    "desktop:verify": "node scripts/desktop-release.mjs verify",
    "desktop:release:preflight": "node scripts/desktop-release.mjs preflight",
    "desktop:publish:artifactory": "node scripts/desktop-release.mjs publish-artifactory"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "github-copilot",
    "agent-skills",
    "sdlc",
    "workflow",
    "git",
    "jira",
    "singularity-flow",
    "copilot-plugin"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "restricted"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
