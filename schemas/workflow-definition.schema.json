{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/singularity-flow/workflow-definition.schema.json",
  "title": "Singularity Flow YAML workflow definition",
  "type": "object",
  "required": ["version", "git", "templatesRoot", "personaPromptsRoot", "personas", "workTypes", "phases"],
  "properties": {
    "version": { "const": 1 },
    "inputsMode": { "enum": ["off", "record", "enforce"], "default": "off" },
    "sequenceGates": { "$ref": "#/$defs/sequenceGates" },
    "defaultBaseBranch": { "type": "string", "minLength": 1 },
    "workItemRoot": { "type": "string", "minLength": 1 },
    "idPattern": { "type": "string", "minLength": 1 },
    "git": {
      "type": "object",
      "required": ["remote", "publish"],
      "properties": {
        "remote": { "type": "string", "minLength": 1 },
        "publish": { "enum": ["required", "off"] }
      },
      "additionalProperties": false
    },
    "templatesRoot": { "type": "string", "minLength": 1 },
    "personaPromptsRoot": { "type": "string", "minLength": 1 },
    "tokens": {
      "type": "object",
      "properties": {
        "mode": { "const": "exact-or-unavailable" },
        "pricing": {
          "type": "object",
          "description": "Optional per-million-token prices keyed by exact provider model name. No prices are assumed by default.",
          "additionalProperties": {
            "type": "object",
            "minProperties": 1,
            "properties": {
              "input": { "type": "number", "minimum": 0 },
              "output": { "type": "number", "minimum": 0 },
              "cachedInput": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "documents": {
      "type": "object",
      "properties": {
        "allowedPhases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "maxFileBytes": { "type": "integer", "minimum": 1 },
        "maxPreviewBytes": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "personas": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["label", "prompt"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "prompt": { "type": "string", "minLength": 1 },
          "suggestedPhases": { "type": "array", "items": { "type": "string" } },
          "worldModelViews": { "type": "array", "items": { "type": "string" } },
          "mayApprove": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "workTypes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["label", "phases"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "phases": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
          "templateOverrides": { "type": "object", "additionalProperties": { "type": "string" } },
          "phaseOverrides": {
            "type": "object",
            "description": "Per-profile overrides for artifact, qualityCommands, worldModel, comparison, approval, or other phase fields.",
            "additionalProperties": {
              "type": "object",
              "properties": { "inputs": { "$ref": "#/$defs/phaseInputs" } }
            }
          },
          "sequenceGates": { "$ref": "#/$defs/sequenceGates" }
        },
        "additionalProperties": true
      }
    },
    "phases": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "properties": {
          "writeScope": { "enum": ["artifact-only", "source-and-artifact"] },
          "inputs": { "$ref": "#/$defs/phaseInputs" }
        }
      }
    },
    "governance": { "type": "object" },
    "worldModel": {
      "type": "object",
      "properties": {
        "outputDir": { "type": "string", "minLength": 1 },
        "promptSource": { "type": "string", "minLength": 1 },
        "runner": { "type": "string", "minLength": 1 },
        "grounding": { "enum": ["off", "warn", "enforce"], "default": "off" },
        "staleness": { "enum": ["warn", "fail", "ignore"] },
        "injection": {
          "type": "object",
          "properties": {
            "placeholder": { "type": "string", "minLength": 1 },
            "mode": { "enum": ["replace", "append", "off"] },
            "maxBytes": { "type": "integer", "minimum": 1 },
            "rules": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["include"],
                "properties": {
                  "when": {
                    "type": "object",
                    "properties": {
                      "persona": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" }, "minItems": 1 }] },
                      "phase": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" }, "minItems": 1 }] },
                      "workType": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" }, "minItems": 1 }] },
                      "changedPaths": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" }, "minItems": 1 }] },
                      "labels": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" }, "minItems": 1 }] }
                    },
                    "additionalProperties": false
                  },
                  "include": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
                  "evidence": { "type": "boolean" },
                  "depth": { "enum": ["quick", "standard", "deep"] }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sequenceGates": {
      "type": "object",
      "properties": {
        "default": { "enum": ["hard", "soft"] },
        "completion": { "enum": ["hard", "soft"] },
        "currentPhase": { "enum": ["hard", "soft"] },
        "phaseStatus": { "enum": ["hard", "soft"] },
        "freshGeneration": { "enum": ["hard", "soft"] },
        "generationCommit": { "enum": ["hard", "soft"] },
        "remoteGeneration": { "enum": ["hard", "soft"] },
        "publicationPending": { "enum": ["hard", "soft"] },
        "documentPhase": { "enum": ["hard", "soft"] }
      },
      "additionalProperties": false
    },
    "phaseInputs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "oneOf": [
          { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          {
            "type": "object",
            "required": ["phase"],
            "properties": {
              "phase": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
              "optional": { "type": "boolean" },
              "maxBytes": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  }
}
