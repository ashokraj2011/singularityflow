{
  "name": "singularity-flow",
  "version": "0.6.1",
  "description": "Singularity Flow: collision-safe sflow-* Copilot skills with YAML-configured work profiles, personas, templates, Git state transfer, and deterministic governance.",
  "type": "module",
  "bin": {
    "singularity-flow": "bin/singularity-flow.mjs",
    "sflow": "bin/singularity-flow.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "plugin/",
    "templates/",
    "schemas/",
    "examples/",
    "README.md",
    "ARCHITECTURE.md",
    "VERIFICATION.md",
    "MIGRATION.md",
    "LICENSE"
  ],
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.mjs",
    "gate": "node scripts/gate.mjs",
    "pack:dry": "npm pack --dry-run",
    "desktop:dev": "npm run dev --workspace singularity-flow-desktop",
    "desktop:build": "npm run build --workspace singularity-flow-desktop",
    "desktop:dist": "npm run dist --workspace singularity-flow-desktop"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "github-copilot",
    "agent-skills",
    "sdlc",
    "workflow",
    "git",
    "jira",
    "singularity-flow",
    "copilot-plugin"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "restricted"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
