{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/singularity-flow/config.schema.json",
  "title": "Singularity Flow repository configuration",
  "type": "object",
  "required": ["schemaVersion", "defaultBaseBranch", "workItemRoot", "idPattern", "phases"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "defaultBaseBranch": { "type": "string", "minLength": 1 },
    "workItemRoot": { "type": "string", "minLength": 1 },
    "idPattern": { "type": "string", "minLength": 1 },
    "artifactScan": {
      "type": "object",
      "properties": {
        "ignorePrefixes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "jira": {
      "type": "object",
      "properties": {
        "issueType": { "type": "string" },
        "maxResults": { "type": "integer", "minimum": 1, "maximum": 100 }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "properties": {
        "requireGithubApprovals": { "type": "boolean" },
        "requireAcceptanceCriteriaTags": { "type": "boolean" },
        "protectedPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "roles": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      },
      "additionalProperties": false
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "owner", "requiredArtifact"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "label": { "type": "string", "minLength": 1 },
          "owner": { "type": ["string", "null"] },
          "requiredArtifact": {
            "type": ["object", "null"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "kind": { "type": "string", "minLength": 1 },
              "minimumBytes": { "type": "integer", "minimum": 1 }
            },
            "required": ["path", "kind", "minimumBytes"],
            "additionalProperties": false
          },
          "qualityCommands": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
