{
  "name": "singularity-flow-desktop",
  "version": "0.9.0",
  "private": true,
  "description": "Visual workflow, approval, persona, artifact-template, and evidence studio for Singularity Flow.",
  "author": "Ashok Raj",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "node electron/dev.mjs",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.3.0",
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.52.2",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "43.1.1",
    "electron-builder": "^26.0.12",
    "vite": "^8.1.5"
  },
  "build": {
    "appId": "dev.singularityflow.desktop",
    "productName": "Singularity Flow",
    "asar": true,
    "forceCodeSigning": false,
    "artifactName": "singularity-flow-desktop-${version}-${os}-${arch}.${ext}",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      { "from": "../../bin", "to": "cli/bin" },
      { "from": "../../src", "to": "cli/src" },
      { "from": "../../templates", "to": "cli/templates" },
      { "from": "../../plugin", "to": "cli/plugin" },
      { "from": "../../HELP.md", "to": "cli/HELP.md" },
      { "from": "../../DISTRIBUTION.md", "to": "cli/DISTRIBUTION.md" },
      { "from": "../../node_modules/yaml", "to": "cli/node_modules/yaml" },
      { "from": "../../package.json", "to": "cli/package.json" }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "notarize": false,
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "zip", "arch": ["universal"] }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "dmg": {
      "title": "Singularity Flow ${version}",
      "contents": [
        { "x": 140, "y": 210, "type": "file" },
        { "x": 400, "y": 210, "type": "link", "path": "/Applications" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Singularity Flow",
      "uninstallDisplayName": "Singularity Flow ${version}",
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "category": "Development",
      "target": ["AppImage", "deb"]
    }
  }
}
