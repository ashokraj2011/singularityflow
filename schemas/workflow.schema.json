{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/singularity-flow/workflow.schema.json",
  "title": "Singularity Flow work-item lifecycle state",
  "type": "object",
  "required": ["schemaVersion", "workItem", "status", "currentPhase", "phaseOrder", "phases", "history"],
  "properties": {
    "schemaVersion": { "enum": [1, 2] },
    "lineage": {
      "type": "object",
      "properties": {
        "schemaVersion": { "const": 1 },
        "canonicalBranch": { "type": "string", "minLength": 1 },
        "parentStoryId": { "type": "string", "minLength": 1 },
        "epicId": { "type": ["string", "null"] },
        "planId": { "type": ["string", "null"] },
        "jiraIssueId": { "type": ["string", "null"] },
        "initialJiraKey": { "type": ["string", "null"] },
        "currentJiraKey": { "type": ["string", "null"] },
        "childBranches": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "workItem": {
      "type": "object",
      "required": ["id", "title", "branch", "baseBranch", "createdAt", "createdBy", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "baseBranch": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "object" },
        "source": { "type": "object" }
      },
      "additionalProperties": true
    },
    "status": { "enum": ["in_progress", "complete"] },
    "resolution": {
      "type": "object",
      "properties": {
        "inputsMode": { "enum": ["off", "record", "enforce"] },
        "worldModelGrounding": { "enum": ["off", "warn", "enforce"] },
        "sequenceGates": { "type": "object", "additionalProperties": { "enum": ["hard", "soft"] } },
        "session": {
          "type": "object",
          "properties": {
            "workItemSelection": { "enum": ["off", "reuse", "prompt"] },
            "personaSelection": { "enum": ["off", "reuse", "prompt"] },
            "promptOnNewSession": { "type": "boolean" },
            "promptOnResume": { "type": "boolean" },
            "requireBeforeTools": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "sessionLegacy": { "type": "boolean" },
        "phases": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "usage": { "type": "object" },
    "telemetry": {
      "type": "object",
      "properties": {
        "schemaVersion": { "const": 1 },
        "mode": { "enum": ["legacy", "work-item-sanitized"] }
      },
      "additionalProperties": true
    },
    "documents": {
      "type": "object",
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "updatedAt": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "collaboration": {
      "type": "object",
      "properties": {
        "assignments": { "type": "object", "additionalProperties": { "type": "object" } },
        "notifications": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "currentPhase": { "type": ["string", "null"] },
    "phaseOrder": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
    "phases": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["id", "label", "status", "artifacts", "checks"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "owner": { "type": ["string", "null"] },
          "status": { "enum": ["not_started", "in_progress", "awaiting_approval", "approved"] },
          "requiredArtifact": { "type": ["object", "null"] },
          "qualityCommands": { "type": "array", "items": { "type": "string" } },
          "inputs": { "type": "array", "items": { "type": "object" } },
          "artifacts": { "type": "array", "items": { "type": "object" } },
          "checks": { "type": "array", "items": { "type": "object" } },
          "telemetry": { "type": "array", "items": { "type": "object" } }
        },
        "additionalProperties": true
      }
    },
    "history": { "type": "array", "items": { "type": "object" } },
    "sequenceOverrides": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
